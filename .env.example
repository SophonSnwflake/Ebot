HOST=127.0.0.1
PORT=8080

# NapCat 反向 WS 连你时带的 Authorization: Bearer <token>
ACCESS_TOKEN=

# 默认触发模式：at 或 all
TRIGGER_MODE=at


$base = "https://api.bltcy.ai"
$key  = ""
$body = @{
  model = "gpt-4o-mini"
  messages = @(
    @{ role="user"; content="只回复：pong" }
  )
  temperature = 0.2
} | ConvertTo-Json -Depth 10

irm "$base/v1/chat/completions" -Method Post -Headers @{
  Authorization="Bearer $key"
  "Content-Type"="application/json"
} -Body $body | ConvertTo-Json -Depth 10
